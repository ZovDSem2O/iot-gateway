    865          static void zclSampleSw_InitUart(void)
    866          {
    867            halUARTCfg_t uartConfig;
    868          
    869            /* UART Configuration */
    870            uartConfig.configured           = TRUE;
    871            uartConfig.baudRate             = HAL_UART_BR_115200;
    872            uartConfig.flowControl          = FALSE;
    873            uartConfig.flowControlThreshold = 0;
    874            uartConfig.rx.maxBufSize        = ZCLSAMPLESW_UART_BUF_LEN;
    875            uartConfig.tx.maxBufSize        = 0;
    876            uartConfig.idleTimeout          = 6;
    877            uartConfig.intEnable            = TRUE;
    878            uartConfig.callBackFunc         = zclSampleSw_UartCB;
    879          
    880            /* Start UART */
    881            HalUARTOpen(HAL_UART_PORT_0, &uartConfig);
    882          }
