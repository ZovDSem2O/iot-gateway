    808          #if defined (OTA_CLIENT) && (OTA_CLIENT == TRUE)
    809          /*********************************************************************
    810           * @fn      zclSampleSw_ProcessOTAMsgs
    811           *
    812           * @brief   Called to process callbacks from the ZCL OTA.
    813           *
    814           * @param   none
    815           *
    816           * @return  none
    817           */
    818          static void zclSampleSw_ProcessOTAMsgs( zclOTA_CallbackMsg_t* pMsg )
    819          {
    820            uint8 RxOnIdle;
    821          
    822            switch(pMsg->ota_event)
    823            {
    824            case ZCL_OTA_START_CALLBACK:
    825              if (pMsg->hdr.status == ZSuccess)
    826              {
    827                // Speed up the poll rate
    828                RxOnIdle = TRUE;
    829                ZMacSetReq( ZMacRxOnIdle, &RxOnIdle );
    830                NLME_SetPollRate( 2000 );
    831              }
    832              break;
    833          
    834            case ZCL_OTA_DL_COMPLETE_CALLBACK:
    835              if (pMsg->hdr.status == ZSuccess)
    836              {
    837                // Reset the CRC Shadow and reboot.  The bootloader will see the
    838                // CRC shadow has been cleared and switch to the new image
    839                HalOTAInvRC();
    840                SystemReset();
    841              }
    842              else
    843              {
    844                // slow the poll rate back down.
    845                RxOnIdle = FALSE;
    846                ZMacSetReq( ZMacRxOnIdle, &RxOnIdle );
    847                NLME_SetPollRate(DEVICE_POLL_RATE);
    848              }
    849              break;
    850          
    851            default:
    852              break;
    853            }
    854          }
    855          #endif // defined (OTA_CLIENT) && (OTA_CLIENT == TRUE)
