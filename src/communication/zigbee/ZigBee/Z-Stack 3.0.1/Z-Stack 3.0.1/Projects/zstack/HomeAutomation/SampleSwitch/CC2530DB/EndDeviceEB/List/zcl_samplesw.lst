    769          /**
    770           * @fn      zclSampleSw_ProcessInReportCmd
    771           *
    772           * @brief   Process the "Profile" Report Command
    773           *
    774           * @param   pInMsg - incoming message to process
    775           *
    776           * @return  none
    777           */
    778          static uint8 zclSampleSw_ProcessInReportCmd( zclIncomingMsg_t *pInMsg )
    779          {
    780            zclReportCmd_t *reportCmd;
    781            uint8 i;
    782            char resstr[10];
    783            HalLcdWriteString("Tem&Hum<-RX", 3);
    784            osal_memset(resstr,0,10);     //ҪвҫцЧЦ·ыҙ®АпГж¶аУаВТВлОКМв
    785            
    786            reportCmd = (zclReportCmd_t *)pInMsg->attrCmd;
    787            for ( i = 0; i < reportCmd->numAttr; i++ )
    788            {
    789              if( pInMsg->clusterId == ZCL_CLUSTER_ID_GEN_ON_OFF_SWITCH_CONFIG && 
    790                  reportCmd->attrList[i].attrID == ATTRID_ON_OFF_SWITCH_TYPE)
    791              {
    792                //////   TODO С§ЙъНкіЙ Ҫ«reportCmd->attrList[i].attrData ёҙЦЖөҪresstr Іў·ўЛН/////
    793                strncpy(resstr,(char const *)reportCmd->attrList[i].attrData,6);        //ҝҪұҙ6ёцКэҫЭ ұИИз14 70
    794                HalUARTWrite(0, "T&H:", 4);       //МбКҫҪУКХөҪКэҫЭ
    795                HalUARTWrite(HAL_UART_PORT_0 ,  reportCmd->attrList[i].attrData , osal_strlen((char *)reportCmd->attrList[i].attrData));
    796                HalUARTWrite(0, "\n",1);         // »Шіө»»РР
    797                //////                        END                                         /////
    798              }
    799            }
    800          
    801            return ( TRUE );
    802          }
    803          #endif // ZCL_REPORT
