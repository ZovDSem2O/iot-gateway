    425          /*********************************************************************
    426           * @fn      zclSampleSw_HandleKeys
    427           *
    428           * @brief   Handles all key events for this device.
    429           *
    430           * @param   shift - true if in shift/alt.
    431           * @param   keys - bit field for key events. Valid entries:
    432           *                 HAL_KEY_SW_5
    433           *                 HAL_KEY_SW_4
    434           *                 HAL_KEY_SW_2
    435           *                 HAL_KEY_SW_1
    436           *
    437           * @return  none
    438           */
    439          static void zclSampleSw_HandleKeys( byte shift, byte keys )
    440          { 
    441            if(keys & HAL_KEY_SW_6)
    442            {
    443              HalLedSet(HAL_LED_2, HAL_LED_MODE_TOGGLE);  
    444            } 
    445          }
